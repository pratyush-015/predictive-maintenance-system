# Copy to `.env` for local development (docker-compose sets these via
# environment: directly in docker-compose.yml instead).

ENVIRONMENT=development
DEBUG=true

# SQLite is the zero-setup default for local dev. For Postgres:
# DATABASE_URL=postgresql+psycopg2://aiops:aiops_dev_password@localhost:5432/aiops
DATABASE_URL=sqlite:///./aiops.db

SECRET_KEY=dev-only-secret-change-in-production
AGENT_API_KEY=dev-agent-key-change-me

CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

INFLUX_ENABLED=false
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=dev-token
INFLUX_ORG=aiops
INFLUX_BUCKET=metrics

ML_MODEL_DIR=../ml/models
DEFAULT_ANOMALY_MODEL=isolation_forest

CPU_ALERT_THRESHOLD=90
MEMORY_ALERT_THRESHOLD=90
DISK_ALERT_THRESHOLD=90
