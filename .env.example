# ============================================================
# Docker Compose environment — copy to `.env` and fill in real
# secrets before running `docker compose up -d`.
# ============================================================

# --- Postgres ---
POSTGRES_USER=aiops
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=aiops

# --- Backend security (REQUIRED — compose will refuse to start without these) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
# Shared secret the monitoring agent authenticates with. Generate similarly.
AGENT_API_KEY=

# --- Public URL the frontend is served from (used for CORS) ---
PUBLIC_ORIGIN=http://localhost

# --- Optional InfluxDB (leave INFLUX_ENABLED=false unless you run --profile influx) ---
INFLUX_ENABLED=false
INFLUX_USERNAME=admin
INFLUX_PASSWORD=change_me_admin_password
INFLUX_ORG=aiops
INFLUX_BUCKET=metrics
INFLUX_TOKEN=change_me_to_a_long_random_token
