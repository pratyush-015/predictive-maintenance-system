# Copy to `.env` in the agent/ directory before running `python main.py`.
# These must match the backend's AGENT_API_KEY and be reachable at BACKEND_URL.

AIOPS_BACKEND_URL=http://localhost:8000
AIOPS_AGENT_API_KEY=dev-agent-key-change-me
AIOPS_DEVICE_TYPE=laptop
AIOPS_COLLECT_INTERVAL=5
AIOPS_FLUSH_INTERVAL=15
AIOPS_TOP_N_PROCESSES=5
AIOPS_LOG_LEVEL=INFO
